version: "3.9"

services:

  db:
    image: postgres:16
    environment:
      POSTGRES_DB: lifereplay
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
    ports:
      - "5432:5432"

  api:
    build: ./apps/api
    ports:
      - "8000:8000"
    depends_on:
      - db

  web:
    build: ./apps/web
    ports:
      - "3000:3000"
    depends_on:
      - api
